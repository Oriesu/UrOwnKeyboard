    def source_matches_filter(self, item, query):
        if not query:
            return True

        haystack = " ".join([
            item.get("section", ""),
            item.get("label", ""),
            item.get("description", ""),
            item.get("source_id", ""),
            item.get("include", ""),
        ]).lower()

        return query.lower() in haystack

