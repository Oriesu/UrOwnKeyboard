#!/usr/bin/env python3
import argparse
import hashlib
import json
import re
import shlex
import shutil
import subprocess
import tempfile
import unicodedata
from pathlib import Path
import sys

HOME = Path.home()
CONFIG = HOME / ".config" / "teclado-indicador"
PROFILES = CONFIG / "profiles"
KEYD_DIR = CONFIG / "keyd"
XKB_DIR = CONFIG / "xkb"
USER_XKB = HOME / ".xkb" / "symbols"
CURRENT_PROFILE = CONFIG / "current-profile.json"

for d in [CONFIG, PROFILES, KEYD_DIR, XKB_DIR, USER_XKB]:
    d.mkdir(parents=True, exist_ok=True)



def refresh_graphical_indicator():
    indicator = HOME / ".local" / "bin" / "teclado-indicador.py"

    if not indicator.exists():
        return

    # Only try to refresh if a graphical session is available.
    import os
    if not os.environ.get("DISPLAY") and not os.environ.get("WAYLAND_DISPLAY"):
        return

    running = subprocess.run(
        ["pgrep", "-f", "teclado-indicador.py"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

    if running.returncode != 0:
        return

    subprocess.run(
        ["pkill", "-f", "teclado-indicador.py"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

    log = open("/tmp/teclado-indicador.log", "a")

    subprocess.Popen(
        [str(indicator)],
        stdin=subprocess.DEVNULL,
        stdout=log,
        stderr=subprocess.STDOUT,
        start_new_session=True,
    )


def ensure_dirs():
    CONFIG.mkdir(parents=True, exist_ok=True)
    PROFILES.mkdir(parents=True, exist_ok=True)
    KEYD_DIR.mkdir(parents=True, exist_ok=True)
    XKB_DIR.mkdir(parents=True, exist_ok=True)
    USER_XKB.mkdir(parents=True, exist_ok=True)

def safe_id(name):
    name = unicodedata.normalize("NFKD", name)
    name = name.encode("ascii", "ignore").decode("ascii")
    name = name.lower()
    name = re.sub(r"[^a-z0-9]+", "_", name)
    name = name.strip("_")
    return name or "configuracion"


def file_hash(path):
    path = Path(path)
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def same_file(a, b):
    if not a and not b:
        return True

    if not a or not b:
        return False

    a = Path(a).expanduser()
    b = Path(b).expanduser()

    if not a.exists() or not b.exists():
        return False

    return file_hash(a) == file_hash(b)


def load_profiles():
    profiles = []

    for file in sorted(PROFILES.glob("*.json")):
        try:
            profile = json.loads(file.read_text())
            profile["_profile_file"] = str(file)
            profiles.append(profile)
        except Exception:
            pass

    return profiles


def find_profile(name_or_id):
    for profile in load_profiles():
        if profile.get("id") == name_or_id or profile.get("name") == name_or_id:
            return profile

    return None


def find_duplicate(xkb_file, keyd_file):
    for profile in load_profiles():
        existing_xkb = profile.get("xkb_file")
        existing_keyd = profile.get("keyd_conf")

        if same_file(xkb_file, existing_xkb) and same_file(keyd_file, existing_keyd):
            return profile

    return None


def unique_layout_id(base_id):
    candidate = base_id
    counter = 2

    while True:
        profile_file = PROFILES / f"{candidate}.json"
        xkb_file = USER_XKB / candidate
        keyd_file = KEYD_DIR / f"{candidate}.conf"

        if not profile_file.exists() and not xkb_file.exists() and not keyd_file.exists():
            return candidate

        candidate = f"{base_id}_{counter}"
        counter += 1


def validate_xkb(layout_id):
    with tempfile.NamedTemporaryFile(prefix="uok-xkb-", suffix=".xkm") as tmp:
        cmd = (
            f'setxkbmap -I"{HOME}/.xkb" -layout {shlex.quote(layout_id)} -print '
            f'| xkbcomp -I"{HOME}/.xkb" -w 0 - {shlex.quote(tmp.name)}'
        )

        result = subprocess.run(
            ["bash", "-lc", cmd],
            text=True,
            capture_output=True,
        )

    return result.returncode == 0, result.stderr.strip() or result.stdout.strip()


def apply_xkb(layout_id):
    cmd = (
        f'setxkbmap -I"{HOME}/.xkb" -layout {shlex.quote(layout_id)} -print '
        f'| xkbcomp -I"{HOME}/.xkb" -w 0 - "$DISPLAY"'
    )

    return subprocess.run(
        ["bash", "-lc", cmd],
        text=True,
    )


def apply_keyd(keyd_conf):
    helper = "/usr/local/sbin/keyd-aplicar-conf"

    cmd = ["sudo", "-n", helper]

    if keyd_conf:
        cmd.append(str(keyd_conf))
    else:
        cmd.append("--off")

    try:
        return subprocess.run(
            cmd,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            timeout=12,
        )
    except subprocess.TimeoutExpired as exc:
        return subprocess.CompletedProcess(
            cmd,
            124,
            exc.stdout or "",
            "Timed out applying keyd.conf. XKB can continue, but keyd was not applied.",
        )


def delete_file_if_safe(path_str):
    if not path_str:
        return

    path = Path(path_str).expanduser().resolve()

    allowed_dirs = [
        USER_XKB.resolve(),
        KEYD_DIR.resolve(),
        XKB_DIR.resolve(),
        PROFILES.resolve(),
    ]

    allowed = any(
        str(path).startswith(str(directory) + "/") or path == directory
        for directory in allowed_dirs
    )

    if allowed and path.exists() and path.is_file():
        path.unlink()


def cmd_list(_args):
    profiles = load_profiles()

    if not profiles:
        print("No imported configurations.")
        return

    current_id = None

    if CURRENT_PROFILE.exists():
        try:
            current_id = json.loads(CURRENT_PROFILE.read_text()).get("id")
        except Exception:
            pass

    for profile in profiles:
        marker = "* " if profile.get("id") == current_id else ""
        keyd_mark = " + keyd" if profile.get("keyd_conf") else ""
        print(f"{marker}{profile.get('id')} — {profile.get('name')}{keyd_mark}")


def cmd_import(args):
    name = args.name
    xkb_file = Path(args.xkb).expanduser().resolve()

    if not xkb_file.exists():
        raise SystemExit(f"XKB file does not exist: {xkb_file}")

    keyd_file = None

    if args.keyd:
        keyd_file = Path(args.keyd).expanduser().resolve()

        if not keyd_file.exists():
            raise SystemExit(f"keyd file does not exist: {keyd_file}")

    duplicate = find_duplicate(xkb_file, keyd_file)

    if duplicate:
        print(f"This configuration already exists: {duplicate['id']} — {duplicate['name']}")
        return

    base_id = safe_id(name)
    layout_id = unique_layout_id(base_id)

    dest_xkb = USER_XKB / layout_id
    shutil.copyfile(xkb_file, dest_xkb)

    dest_keyd = None

    if keyd_file:
        dest_keyd = KEYD_DIR / f"{layout_id}.conf"
        shutil.copyfile(keyd_file, dest_keyd)

    ok, error = validate_xkb(layout_id)

    if not ok:
        delete_file_if_safe(str(dest_xkb))
        delete_file_if_safe(str(dest_keyd) if dest_keyd else None)
        raise SystemExit(
            "The XKB file was copied temporarily, but it does not compile with XKB.\n"
            "The configuration was not saved.\n\n"
            f"Details:\n{error}"
        )

    profile = {
        "type": "imported-profile",
        "id": layout_id,
        "name": name,
        "xkb_file": str(dest_xkb),
    }

    if dest_keyd:
        profile["keyd_conf"] = str(dest_keyd)

    (PROFILES / f"{layout_id}.json").write_text(
        json.dumps(profile, indent=2, ensure_ascii=False)
    )

    suffix = " with keyd" if dest_keyd else ""

    if layout_id != base_id:
        print(f"Configuration imported as: {layout_id}{suffix}")
    else:
        print(f"Configuration imported: {layout_id}{suffix}")

    refresh_graphical_indicator()


def cmd_activate(args):
    profile = find_profile(args.profile)

    if not profile:
        raise SystemExit(f"Configuration does not exist: {args.profile}")

    layout_id = profile["id"]
    keyd_conf = profile.get("keyd_conf")

    keyd_warning = ""

    # keyd es opcional. Si falla, avisamos pero no bloqueamos XKB.
    # Esto evita que un problema del daemon keyd impida activar el teclado creado.
    result = apply_keyd(keyd_conf)

    if result.returncode != 0:
        keyd_warning = "WARNING: keyd could not be applied. XKB was activated, but the physical keyd shortcuts/remaps were not."

    subprocess.run(["sleep", "0.4"], text=True)

    # Apply XKB last, using xkbcomp. This is the method that works manually.
    result = apply_xkb(layout_id)

    if result.returncode != 0:
        raise SystemExit("Could not apply the XKB layout.")

    current = dict(profile)
    current["type"] = "imported-profile"

    if keyd_warning:
        current["keyd_warning"] = keyd_warning

    CURRENT_PROFILE.write_text(
        json.dumps(current, indent=2, ensure_ascii=False)
    )

    print(f"Active configuration: {profile['name']}")

    if keyd_warning:
        print(keyd_warning, file=sys.stderr)


def cmd_delete(args):
    profile = find_profile(args.profile)

    if not profile:
        raise SystemExit(f"Configuration does not exist: {args.profile}")

    delete_file_if_safe(profile.get("xkb_file"))
    delete_file_if_safe(profile.get("keyd_conf"))
    delete_file_if_safe(profile.get("_profile_file"))

    if CURRENT_PROFILE.exists():
        try:
            current = json.loads(CURRENT_PROFILE.read_text())
            if current.get("id") == profile.get("id"):
                CURRENT_PROFILE.unlink()
        except Exception:
            pass

    print(f"Configuration deleted: {profile['name']}")

    refresh_graphical_indicator()


def cmd_current(_args):
    if not CURRENT_PROFILE.exists():
        print("No active configuration registered by UrOwnKeyboard.")
        return

    print(CURRENT_PROFILE.read_text())


def cmd_show_keyd(_args):
    if not CURRENT_PROFILE.exists():
        print("No active configuration registered by UrOwnKeyboard.")
        return

    profile = json.loads(CURRENT_PROFILE.read_text())
    keyd_conf = profile.get("keyd_conf")

    if not keyd_conf:
        print("The active configuration has no associated keyd.conf.")
        return

    path = Path(keyd_conf).expanduser()

    if not path.exists():
        print(f"The active configuration references a missing keyd.conf: {path}")
        return

    print(path.read_text())



def cmd_restore(_args):
    ensure_dirs()

    if not CURRENT_PROFILE.exists():
        result = apply_keyd("")
        if result.returncode == 0:
            print("No active UrOwnKeyboard profile. keyd disabled.")
            return
        raise SystemExit("No active UrOwnKeyboard profile, but keyd could not be disabled.")

    try:
        profile = json.loads(CURRENT_PROFILE.read_text())
    except Exception:
        apply_keyd("")
        raise SystemExit("Invalid current profile file. keyd disabled.")

    profile_type = profile.get("type")

    if profile_type == "imported-profile":
        profile_id = profile.get("id")

        if not profile_id:
            apply_keyd("")
            raise SystemExit("Invalid imported profile. keyd disabled.")

        class Args:
            pass

        args = Args()
        args.profile = profile_id

        return cmd_activate(args)

    result = apply_keyd("")

    if result.returncode == 0:
        print("Regular input source restored. keyd disabled.")
        return

    raise SystemExit("Regular input source restored, but keyd could not be disabled.")


def cmd_editor(_args):
    import os
    import subprocess
    import sys

    candidates = [
        Path(__file__).resolve().parent / "uok-layout-editor.py",
        HOME / ".local" / "bin" / "uok-layout-editor.py",
        Path.cwd() / "uok-layout-editor.py",
    ]

    editor = next((path for path in candidates if path.exists()), None)

    if editor is None:
        raise SystemExit(
            "No se encontró uok-layout-editor.py.\n"
            "Ejecuta ./install.sh o abre el editor desde la raíz del repositorio."
        )

    env = os.environ.copy()

    if not env.get("DISPLAY") and not env.get("WAYLAND_DISPLAY"):
        raise SystemExit("No hay sesión gráfica disponible para abrir el editor.")

    subprocess.Popen(
        [sys.executable, str(editor)],
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        env=env,
        start_new_session=True,
    )

    print("Editor visual abierto.")




def run_capture(cmd):
    try:
        return subprocess.run(
            cmd,
            text=True,
            capture_output=True,
            check=False,
        )
    except FileNotFoundError:
        return None


def _uok_parse_gsettings_sources(value):
    """
    Parse values like:
      [('xkb', 'es'), ('xkb', 'de')]
      [('xkb', 'es+winkeys')]
      [('ibus', 'xkb:es::spa')]
    Return XKB layout strings suitable for xkbcli where possible.
    """
    out = []

    for typ, name in re.findall(r"\('([^']+)'\s*,\s*'([^']+)'\)", value or ""):
        if typ == "xkb":
            out.append(name)
        elif typ == "ibus" and name.startswith("xkb:"):
            # xkb:layout:variant:lang
            parts = name.split(":")
            if len(parts) >= 2 and parts[1]:
                layout = parts[1]
                variant = parts[2] if len(parts) >= 3 else ""
                out.append(f"{layout}+{variant}" if variant else layout)

    return out


def _uok_current_layouts_for_doctor():
    layouts = []

    # GNOME / Cinnamon / compatible desktops.
    result = run_capture([
        "gsettings",
        "get",
        "org.gnome.desktop.input-sources",
        "sources",
    ])
    if result and result.returncode == 0:
        layouts.extend(_uok_parse_gsettings_sources(result.stdout.strip()))

    # X11 / Xwayland fallback.
    result = run_capture(["setxkbmap", "-query"])
    if result and result.stdout:
        m = re.search(r"(?m)^\s*layout:\s*(.+?)\s*$", result.stdout)
        v = re.search(r"(?m)^\s*variant:\s*(.+?)\s*$", result.stdout)

        if m:
            ls = [x.strip() for x in m.group(1).split(",") if x.strip()]
            vs = []
            if v:
                vs = [x.strip() for x in v.group(1).split(",")]

            for i, layout in enumerate(ls):
                variant = vs[i] if i < len(vs) else ""
                layouts.append(f"{layout}+{variant}" if variant else layout)

    # System fallback.
    result = run_capture(["localectl", "status"])
    if result and result.stdout:
        m = re.search(r"(?m)^\s*X11 Layout:\s*(.+?)\s*$", result.stdout)
        v = re.search(r"(?m)^\s*X11 Variant:\s*(.+?)\s*$", result.stdout)

        if m:
            ls = [x.strip() for x in m.group(1).split(",") if x.strip()]
            vs = []
            if v:
                vs = [x.strip() for x in v.group(1).split(",")]

            for i, layout in enumerate(ls):
                variant = vs[i] if i < len(vs) else ""
                layouts.append(f"{layout}+{variant}" if variant else layout)

    # Deduplicate preserving order.
    clean = []
    for item in layouts:
        item = item.strip()
        if item and item not in clean:
            clean.append(item)

    return clean


def _uok_compile_layout(layout):
    if "+" in layout:
        base, variant = layout.split("+", 1)
        if variant:
            return ["xkbcli", "compile-keymap", "--layout", base, "--variant", variant]
        return ["xkbcli", "compile-keymap", "--layout", base]

    return ["xkbcli", "compile-keymap", "--layout", layout]


def cmd_doctor(args):
    """
    Diagnose global XKB registry problems.

    This is important on Wayland desktops: if evdev.xml is invalid,
    the desktop can show the expected layout while the compositor
    actually falls back to another layout.
    """
    problems = []

    rules = Path("/usr/share/X11/xkb/rules/evdev.xml")
    dtd = Path("/usr/share/X11/xkb/rules/xkb.dtd")

    print("UrOwnKeyboard doctor")
    print("====================")
    print()

    print("== XKB registry ==")

    if not rules.exists():
        problems.append(f"Missing {rules}")
        print(f"ERROR: missing {rules}")
    else:
        print(f"Found: {rules}")

    if rules.exists() and dtd.exists() and shutil.which("xmllint"):
        result = run_capture([
            "xmllint",
            "--noout",
            "--dtdvalid",
            str(dtd),
            str(rules),
        ])

        if result and result.returncode == 0:
            print("evdev.xml: OK")
        else:
            problems.append("Invalid XKB registry XML: evdev.xml")
            print("ERROR: evdev.xml is invalid")
            if result:
                msg = (result.stderr or result.stdout or "").strip()
                if msg:
                    print(msg[:4000])

    elif rules.exists() and shutil.which("xkbcli"):
        result = run_capture(["xkbcli", "list"])

        output = ""
        if result:
            output = ((result.stdout or "") + "\n" + (result.stderr or "")).strip()

        bad_words = [
            "xkbregistry: ERROR",
            "XML error",
            "failed to validate",
            "Failed to load",
        ]

        if result is None:
            print("WARNING: could not run xkbcli")
        elif result.returncode != 0 or any(w in output for w in bad_words):
            problems.append("Invalid XKB registry XML: evdev.xml")
            print("ERROR: XKB registry check failed")
            if output:
                print(output[:4000])
        else:
            print("xkbcli registry check: OK")

    else:
        print("WARNING: cannot fully validate evdev.xml.")
        print("Install one of these for stronger checks:")
        print("  sudo apt install -y libxml2-utils libxkbcommon-tools")

    print()
    print("== XKB layout compile ==")

    layouts = _uok_current_layouts_for_doctor()

    if not layouts:
        layouts = ["us"]
        print("Could not detect current layouts; using fallback layout: us")
    else:
        print("Detected layouts:", ", ".join(layouts))

    if shutil.which("xkbcli"):
        for layout in layouts:
            result = run_capture(_uok_compile_layout(layout))

            if result and result.returncode == 0:
                print(f"layout {layout}: OK")
            else:
                problems.append(f"Could not compile XKB layout: {layout}")
                print(f"ERROR: could not compile layout {layout}")
                if result:
                    msg = (result.stderr or result.stdout or "").strip()
                    if msg:
                        print(msg[:4000])
    else:
        print("WARNING: xkbcli not installed; skipping compile check.")

    if not args.system_only:
        print()
        print("== Current session ==")

        checks = [
            ("XDG_CURRENT_DESKTOP", ["bash", "-lc", "printf '%s' \"$XDG_CURRENT_DESKTOP\""]),
            ("DESKTOP_SESSION", ["bash", "-lc", "printf '%s' \"$DESKTOP_SESSION\""]),
            ("XDG_SESSION_TYPE", ["bash", "-lc", "printf '%s' \"$XDG_SESSION_TYPE\""]),
            ("GNOME sources", ["gsettings", "get", "org.gnome.desktop.input-sources", "sources"]),
            ("GNOME current", ["gsettings", "get", "org.gnome.desktop.input-sources", "current"]),
            ("IBus engine", ["ibus", "engine"]),
            ("keyd service", ["systemctl", "is-active", "keyd"]),
        ]

        for label, cmd in checks:
            result = run_capture(cmd)
            if result is None:
                print(f"{label}: unavailable")
            else:
                value = (result.stdout or result.stderr or "").strip()
                print(f"{label}: {value}")

    print()

    if problems:
        print("Problems found:")
        for problem in problems:
            print(f"  - {problem}")

        print()
        print("Recommended repair on Debian/Ubuntu:")
        print("  sudo apt install --reinstall -y xkb-data")
        print()
        print("Recommended repair on Fedora:")
        print("  sudo dnf reinstall xkeyboard-config")
        print()
        print("Recommended repair on Arch:")
        print("  sudo pacman -S xkeyboard-config")
        print()
        print("After repairing, log out and log back in.")

        if not args.no_fail:
            raise SystemExit(2)

    print("No blocking XKB registry problems detected.")


def main():
    parser = argparse.ArgumentParser(
        prog="uok",
        description="UrOwnKeyboard: portable XKB + keyd configuration manager",
        epilog="""Examples:
  uok list
  uok import --name "My keyboard" --xkb ./my_keyboard
  uok import --name "My keyboard" --xkb ./my_keyboard --keyd ./my_keyboard.keyd.conf
  uok activate my_keyboard
  uok delete my_keyboard
  uok current
  uok show-keyd
  uok restore

Command-specific help:
  uok import -h
  uok activate -h
  uok delete -h
""",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )

    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("list", help="List imported configurations")
    p.set_defaults(func=cmd_list)

    p = sub.add_parser("import", help="Import a configuration")
    p.add_argument("--name", required=True, help="Visible configuration name")
    p.add_argument("--xkb", required=True, help="XKB file / symbols")
    p.add_argument("--keyd", help="keyd file.conf opcional")
    p.set_defaults(func=cmd_import)

    p = sub.add_parser("activate", help="Activate a configuration")
    p.add_argument("profile", help="Configuration ID or name")
    p.set_defaults(func=cmd_activate)

    p = sub.add_parser("delete", help="Delete a configuration")
    p.add_argument("profile", help="Configuration ID or name")
    p.set_defaults(func=cmd_delete)

    p = sub.add_parser("current", help="Show the registered active configuration")
    p.set_defaults(func=cmd_current)

    p = sub.add_parser("show-keyd", help="Show the keyd.conf associated with the active configuration")
    p.set_defaults(func=cmd_show_keyd)

    p = sub.add_parser("restore", help="Restore the last active UrOwnKeyboard configuration")
    p.set_defaults(func=cmd_restore)

    p = sub.add_parser(
        "editor",
        aliases=["open-editor", "visual-editor", "layout-editor"],
        help="Open the visual keyboard layout editor",
    )
    p.set_defaults(func=cmd_editor)

    p = sub.add_parser("doctor", help="Diagnose XKB, GNOME, IBus and keyd state")
    p.add_argument(
        "--system-only",
        action="store_true",
        help="Only check global XKB registry/keymap health",
    )
    p.add_argument(
        "--no-fail",
        action="store_true",
        help="Print problems but return success",
    )
    p.set_defaults(func=cmd_doctor)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
