#!/bin/sh
set -eu

TARGET=/etc/keyd/default.conf
arg="${1:-}"

mkdir -p /etc/keyd

if [ "$arg" = "--off" ] || [ -z "$arg" ]; then
    cat > "$TARGET" <<'CONF'
# Neutral keyd configuration generated by UrOwnKeyboard.
[ids]
*

[main]
CONF
else
    if [ ! -f "$arg" ]; then
        echo "keyd.conf no existe: $arg" >&2
        exit 2
    fi
    cp "$arg" "$TARGET"
fi

if command -v keyd >/dev/null 2>&1; then
    keyd reload >/dev/null 2>&1 || systemctl restart keyd >/dev/null 2>&1 || true
else
    systemctl restart keyd >/dev/null 2>&1 || true
fi
