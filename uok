    d.mkdir(parents=True, exist_ok=True)

def refresh_graphical_indicator():
    # Do not kill/restart teclado-indicador from the CLI.
    # The visual editor imports through `python3 ./uok import`; older versions
    # used to pkill every teclado-indicador.py process and relaunch the installed
    # one from ~/.local/bin, which made the patched test indicator disappear and
    # the old installed menu come back.
    #
    # GUI callers that live inside the indicator refresh the menu in-process via
    # refrescar_menu_indicador(). External callers (CLI/editor) leave the running
    # indicator alive; the user can choose "Reload list" if needed.
    return

def ensure_dirs():
    CONFIG.mkdir(parents=True, exist_ok=True)
    PROFILES.mkdir(parents=True, exist_ok=True)
    KEYD_DIR.mkdir(parents=True, exist_ok=True)
    XKB_DIR.mkdir(parents=True, exist_ok=True)
    USER_XKB.mkdir(parents=True, exist_ok=True)

def validate_xkb(layout_id):
    with tempfile.NamedTemporaryFile(prefix="uok-xkb-", suffix=".xkm") as tmp:
        cmd = (f'setxkbmap -I"{HOME}/.xkb" -layout {shlex.quote(layout_id)} -print '
            f'| xkbcomp -I"{HOME}/.xkb" -w 0 - {shlex.quote(tmp.name)}')
        result = subprocess.run(["bash", "-lc", cmd],text=True,capture_output=True)
    return result.returncode == 0, result.stderr.strip() or result.stdout.strip()

def apply_xkb(layout_id):
    cmd = (f'setxkbmap -I"{HOME}/.xkb" -layout {shlex.quote(layout_id)} -print '
        f'| xkbcomp -I"{HOME}/.xkb" -w 0 - "$DISPLAY"')
    return subprocess.run(["bash", "-lc", cmd],text=True)

def apply_keyd(keyd_conf):
    helper = "/usr/local/sbin/keyd-aplicar-conf"
    cmd = ["sudo", "-n", helper]
    if keyd_conf:
        cmd.append(str(keyd_conf))
    else:
        cmd.append("--off")
    try:
        return subprocess.run(cmd,text=True,stdout=subprocess.PIPE,stderr=subprocess.PIPE,timeout=12)
    except subprocess.TimeoutExpired as exc:
        return subprocess.CompletedProcess(cmd,124,exc.stdout or "","Timed out applying keyd.conf. XKB can continue, but keyd was not applied.")

LAYOUT_LABELS = {"es":"Spanish","de":"German","us":"US English","gb":"UK English","fr":"French","it":"Italiano","pt":"Portuguese","br":"Portuguese (Brazil)"}


def system_source_label(source_type, source_id):
    source_id = str(source_id or "")
    if source_type == "xkb":
        if "+" in source_id:
            layout, variant = source_id.split("+", 1)
        else:
            layout, variant = source_id, ""
        label = LAYOUT_LABELS.get(layout, layout.upper() if layout else source_id)
        return f"{label} ({variant})" if variant else label
    if source_type == "ibus":
        return f"IBus: {source_id}"
    return f"{source_type}: {source_id}"


def current_system_sources():
    sources = list(system_sources.current_sources())
    if sources:
        return sources
    # Fallback: never let `uok list` hide the user's GNOME input sources just
    # because desktop/session detection failed or an installed command is run
    # outside the expected graphical environment. This still lists only the
    # sources the user has added, not the full system catalogue.
    try:
        return list(system_sources.gnome_sources())
    except Exception:
        return []


def find_system_source(query):
    wanted = str(query or "").strip().lower()
    if not wanted:
        return None
    for index, source in enumerate(current_system_sources()):
        if len(source) < 2:
            continue
        source_type, source_id = source[0], source[1]
        label = system_source_label(source_type, source_id)
        candidates = {
            str(source_id).lower(),
            source_id_to_include(source_id).lower(),
            label.lower(),
            f"{source_type}:{source_id}".lower(),
            str(index),
        }
        if wanted in candidates:
            return {"index": index, "source_type": source_type, "source_id": source_id, "name": label}
    return None


def setxkbmap_apply_source(source_type, source_id):
    if source_type != "xkb" or not source_id:
        return subprocess.CompletedProcess(["setxkbmap"], 2, "", "Fuente XKB no válida.")
    if "+" in source_id:
        layout, variant = source_id.split("+", 1)
        cmd = ["setxkbmap", layout]
        if variant:
            cmd.extend(["-variant", variant])
    else:
        cmd = ["setxkbmap", source_id]
    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=False)


def activate_system_source(source):
    source_type = source["source_type"]
    source_id = source["source_id"]
    label = source["name"]
    if source_type != "xkb":
        raise SystemExit(f"UOK CLI sólo puede activar fuentes XKB del sistema por ahora: {source_type}:{source_id}")
    keyd_result = apply_keyd("")
    keyd_warning = ""
    if keyd_result.returncode != 0:
        keyd_warning = "WARNING: keyd could not be disabled. The layout was activated, but previous keyd remaps may remain."
    if is_gnome_wayland():
        result = activate_gnome_source_id(source_id)
        if not result.ok:
            details = ("\n\n" + result.details) if result.details else ""
            raise SystemExit(result.message + details)
        desktop = "gnome-wayland"
    else:
        result = setxkbmap_apply_source(source_type, source_id)
        if result.returncode != 0:
            raise SystemExit("No se pudo activar la fuente XKB del sistema.\n\n" + ((result.stderr or result.stdout or "").strip()))
        desktop = os.environ.get("XDG_CURRENT_DESKTOP", "x11") or "x11"
    current = {"type":"gnome-source","name":label,"source_type":source_type,"source_id":source_id,"desktop":desktop,"keyd_conf":None}
    CURRENT_PROFILE.write_text(json.dumps(current, indent=2, ensure_ascii=False))
    print(f"Active system source: {label} ({source_id})")
    if keyd_warning:
        print(keyd_warning, file=sys.stderr)

def delete_file_if_safe(path_str):
    if not path_str:
        return
    path = Path(path_str).expanduser().resolve()
    allowed_dirs = [USER_XKB.resolve(),KEYD_DIR.resolve(),XKB_DIR.resolve(),PROFILES.resolve()]
    allowed = any(str(path).startswith(str(directory) + "/") or path == directory
        for directory in allowed_dirs)
    if allowed and path.exists() and path.is_file():
        path.unlink()

def _uok_norm_source_id(value):
    return re.sub(r"_+", "_", str(value or "").strip()).lower()

def _uok_profile_system_ids(profiles):
    ids = set()
    for p in profiles or []:
        for key in ("system_xkb_id", "id"):
            value = p.get(key) if isinstance(p, dict) else None
            if value:
                ids.add(str(value))
                ids.add(_uok_norm_source_id(value))
    return ids

def cmd_list(_args):
    profiles = load_profiles()
    uok_system_ids = _uok_profile_system_ids(profiles)
    sources = [s for s in current_system_sources() if len(s) >= 2 and not (s[0] == "xkb" and (str(s[1]) in uok_system_ids or _uok_norm_source_id(s[1]) in uok_system_ids))]
    current = {}
    if CURRENT_PROFILE.exists():
        try:
            current = json.loads(CURRENT_PROFILE.read_text())
        except Exception:
            current = {}
    current_id = current.get("id")
    current_source = (current.get("source_type"), current.get("source_id")) if current.get("type") == "gnome-source" else None
    if sources:
        print("System sources:")
        for index, source in enumerate(sources):
            if len(source) < 2:
                continue
            source_type, source_id = source[0], source[1]
            label = system_source_label(source_type, source_id)
            marker = "* " if current_source == (source_type, source_id) else "  "
            print(f"{marker}{index}: {source_id} — {label}")
    else:
        print("System sources: none detected.")
    print()
    if profiles:
        print("UOK profiles:")
        for profile in profiles:
            marker = "* " if profile.get("id") == current_id else "  "
            keyd_mark = " + keyd" if profile.get("keyd_conf") else ""
            wayland_mark = " + wayland" if profile.get("wayland_ready") or profile.get("system_xkb_id") else ""
            print(f"{marker}{profile.get('id')} — {profile.get('name')}{keyd_mark}{wayland_mark}")
    else:
        print("UOK profiles: none imported.")

def cmd_import(args):
    name = args.name
    xkb_file = Path(args.xkb).expanduser().resolve()
    if not xkb_file.exists():
        raise SystemExit(f"XKB file does not exist: {xkb_file}")
    keyd_file = None
    if args.keyd:
        keyd_file = Path(args.keyd).expanduser().resolve()
        if not keyd_file.exists():
            raise SystemExit(f"keyd file does not exist: {keyd_file}")
    duplicate = find_duplicate(xkb_file, keyd_file)
    if duplicate:
        print(f"This configuration already exists: {duplicate['id']} — {duplicate['name']}")
        return
    base_id = safe_id(name)
    layout_id = unique_layout_id(base_id)
    dest_xkb = USER_XKB / layout_id
    shutil.copyfile(xkb_file, dest_xkb)
    dest_keyd = None
    if keyd_file:
        dest_keyd = KEYD_DIR / f"{layout_id}.conf"
        shutil.copyfile(keyd_file, dest_keyd)
    ok, error = validate_xkb(layout_id)
    if not ok:
        delete_file_if_safe(str(dest_xkb))
        delete_file_if_safe(str(dest_keyd) if dest_keyd else None)
        raise SystemExit("The XKB file was copied temporarily, but it does not compile with XKB.\n"
            "The configuration was not saved.\n\n"
            f"Details:\n{error}")
    profile = {"type":"imported-profile","id":layout_id,"name":name,"xkb_file":str(dest_xkb)}
    if dest_keyd:
        profile["keyd_conf"] = str(dest_keyd)
    profile_file = PROFILES / f"{layout_id}.json"
    profile_file.write_text(json.dumps(profile, indent=2, ensure_ascii=False))
    if is_gnome_wayland():
        # On GNOME Wayland, custom XKB profiles must exist as GNOME/system
        # input sources. Install/add immediately, but keep the visible item as
        # a UOK profile; the implementation source is hidden from UOK menus.
        profile["_profile_file"] = str(profile_file)
        wayland_result = ensure_profile_available_in_gnome(profile)
        if not wayland_result.ok:
            print("WARNING: imported, but could not install for GNOME Wayland.", file=sys.stderr)
            if wayland_result.details:
                print(wayland_result.details, file=sys.stderr)
        else:
            print("GNOME Wayland: if this is the first time you use this custom layout, log out and back in before testing it.")
    suffix = " with keyd" if dest_keyd else ""
    if layout_id != base_id:
        print(f"Configuration imported as: {layout_id}{suffix}")
    else:
        print(f"Configuration imported: {layout_id}{suffix}")
    refresh_graphical_indicator()

def cmd_activate(args):
    profile = find_profile(args.profile)
    if not profile:
        source = find_system_source(args.profile)
        if source:
            return activate_system_source(source)
        raise SystemExit(f"Configuration or system source does not exist: {args.profile}")
    layout_id = profile["id"]
    keyd_conf = profile.get("keyd_conf")
    keyd_warning = ""

    if is_gnome_wayland():
        # Ensure profile is installed/added, then activate its hidden GNOME source.
        result = activate_profile_gnome_wayland(profile)
        if not result.ok:
            details = ("\n\n" + result.details) if result.details else ""
            raise SystemExit(result.message + details)
        system_id = result.message
        keyd_result = apply_keyd(keyd_conf)
        if keyd_result.returncode != 0 and keyd_conf:
            keyd_warning = "WARNING: keyd could not be applied. The GNOME Wayland layout was activated, but physical shortcuts/remaps were not."
        current = dict(profile)
        current["type"] = "imported-profile"
        current["desktop"] = "gnome-wayland"
        current["system_xkb_id"] = system_id
        current["wayland_ready"] = True
        if keyd_warning:
            current["keyd_warning"] = keyd_warning
        CURRENT_PROFILE.write_text(json.dumps(current, indent=2, ensure_ascii=False))
        print(f"Active configuration: {profile['name']} ({layout_id})")
        if keyd_warning:
            print(keyd_warning, file=sys.stderr)
        return

    # keyd es opcional. Si falla, avisamos pero no bloqueamos XKB.
    # Esto evita que un problema del daemon keyd impida activar el teclado creado.
    result = apply_keyd(keyd_conf)
    if result.returncode != 0:
        keyd_warning = "WARNING: keyd could not be applied. XKB was activated, but the physical keyd shortcuts/remaps were not."
    subprocess.run(["sleep", "0.4"], text=True)
    # Apply XKB last, using xkbcomp. This is the method that works manually.
    result = apply_xkb(layout_id)
    if result.returncode != 0:
        raise SystemExit("Could not apply the XKB layout.")
    current = dict(profile)
    current["type"] = "imported-profile"
    if keyd_warning:
        current["keyd_warning"] = keyd_warning
    CURRENT_PROFILE.write_text(json.dumps(current, indent=2, ensure_ascii=False))
    print(f"Active configuration: {profile['name']}")
    if keyd_warning:
        print(keyd_warning, file=sys.stderr)

def cmd_delete(args):
    profile = find_profile(args.profile)
    if not profile:
        raise SystemExit(f"Configuration does not exist: {args.profile}")

    cleanup_warning = None
    if is_gnome_wayland() or profile.get("wayland_ready") or profile.get("system_xkb_id"):
        cleanup = remove_profile_system_layout(profile)
        if not cleanup.ok:
            cleanup_warning = cleanup.details or cleanup.message

    delete_file_if_safe(profile.get("xkb_file"))
    delete_file_if_safe(profile.get("keyd_conf"))
    delete_file_if_safe(profile.get("_profile_file"))
    if CURRENT_PROFILE.exists():
        try:
            current = json.loads(CURRENT_PROFILE.read_text())
            if current.get("id") == profile.get("id"):
                CURRENT_PROFILE.unlink()
        except Exception:
            pass
    print(f"Configuration deleted: {profile['name']}")
    if cleanup_warning:
        print("WARNING: The profile was deleted, but the GNOME Wayland system layout could not be fully cleaned:", file=sys.stderr)
        print(cleanup_warning, file=sys.stderr)
    refresh_graphical_indicator()


def _uok_evdev_marker_ids():
    try:
        text = EVDEV_XML.read_text(encoding="utf-8", errors="ignore")
    except Exception:
        return set()
    return set(re.findall(r"<!--\s*UOK layout:\s*([^\s<]+)\s*-->", text))


def _uok_evdev_plain_ids():
    path = Path("/usr/share/X11/xkb/rules/evdev")
    try:
        text = path.read_text(encoding="utf-8", errors="ignore")
    except Exception:
        return set()
    out = set()
    for line in text.splitlines():
        m = re.match(r"^\s*([A-Za-z0-9_.-]+)\s*=\s*\1\s*$", line)
        if m:
            out.add(m.group(1))
    return out


def _uok_known_wayland_ids(profiles):
    canonical = set()
    legacy = set()
    for profile in profiles or []:
        try:
            cid = profile_system_xkb_id(profile)
            if cid:
                canonical.add(cid)
        except Exception:
            pass
        try:
            for sid in legacy_profile_system_xkb_ids(profile):
                if sid:
                    legacy.add(str(sid))
        except Exception:
            pass
        for key in ("id", "system_xkb_id"):
            value = profile.get(key) if isinstance(profile, dict) else None
            if value:
                legacy.add(str(value))
    return canonical, legacy


def _uok_cleanup_wayland_candidates():
    profiles = load_profiles()
    canonical_ids, known_ids = _uok_known_wayland_ids(profiles)
    stale_known_ids = known_ids - canonical_ids
    marker_ids = _uok_evdev_marker_ids()
    plain_ids = _uok_evdev_plain_ids()
    source_ids = {sid for stype, sid in system_sources.gnome_sources() if stype == "xkb"}

    remove_ids = set()
    reasons = {}

    def add(system_id, reason):
        system_id = str(system_id or "").strip()
        if not system_id or system_id in canonical_ids:
            return
        remove_ids.add(system_id)
        reasons.setdefault(system_id, set()).add(reason)

    # UOK blocks in evdev.xml whose profile no longer exists.
    for system_id in marker_ids:
        if system_id not in known_ids:
            add(system_id, "registered in evdev.xml but has no UOK profile")

    # Legacy technical ids for profiles that now use profile.id directly.
    # Only report them if there is still something concrete to remove.
    # Otherwise cleanup-wayland would keep reporting stale ids forever just
    # because legacy_profile_system_xkb_ids(profile) can derive old names.
    for system_id in stale_known_ids:
        if (
            system_id in source_ids
            or system_id in marker_ids
            or system_id in plain_ids
            or system_layout_file(system_id).exists()
        ):
            add(system_id, "stale legacy technical id for an existing profile")

    # GNOME sources left over after a profile JSON was deleted.  Be conservative:
    # remove non-profile sources only if they carry the UOK prefix, or if they are
    # present in UOK's marked registry/plain rules.
    for system_id in source_ids:
        if system_id in canonical_ids:
            continue
        if system_id in stale_known_ids:
            add(system_id, "stale GNOME source for an existing profile")
        elif system_id in marker_ids or system_id in plain_ids:
            if system_id not in known_ids:
                add(system_id, "GNOME source registered by UOK but has no profile")
        elif system_id.startswith("uok_") and system_id not in known_ids:
            add(system_id, "orphan GNOME source with UOK prefix")

    # Symbols files that correspond to the ids above can be deleted with the same
    # privileged helper. Missing files are harmless.
    return sorted(remove_ids), {k: sorted(v) for k, v in reasons.items()}


def cmd_cleanup_wayland(args):
    ids, reasons = _uok_cleanup_wayland_candidates()
    if not ids:
        print("No orphan GNOME Wayland UOK layouts found.")
        return

    print("Orphan/stale GNOME Wayland UOK layouts:")
    for system_id in ids:
        detail = "; ".join(reasons.get(system_id, []))
        suffix = f" — {detail}" if detail else ""
        print(f"  - {system_id}{suffix}")
    print()

    if getattr(args, "dry_run", False):
        print("Dry run only. Nothing was removed.")
        return

    if not getattr(args, "yes", False):
        answer = input("Remove these orphan/stale Wayland layouts now? [y/N] ").strip().lower()
        if answer not in {"y", "yes", "s", "si", "sí"}:
            print("Cleanup cancelled.")
            return

    warnings = []
    for system_id in ids:
        result = remove_gnome_source(system_id)
        if not result.ok:
            warnings.append(f"{system_id}: {result.details or result.message}")

    privileged_ids = []
    marker_ids = _uok_evdev_marker_ids()
    plain_ids = _uok_evdev_plain_ids()
    for system_id in ids:
        if system_id in marker_ids or system_id in plain_ids or system_layout_file(system_id).exists():
            privileged_ids.append(system_id)
    if privileged_ids:
        result = remove_system_layouts(privileged_ids)
        if not result.ok:
            warnings.append(result.details or result.message)

    if warnings:
        print("Cleanup completed with warnings:", file=sys.stderr)
        for warning in warnings:
            print("  - " + warning, file=sys.stderr)
    else:
        print("Cleanup completed.")


def cmd_current(_args):
    if not CURRENT_PROFILE.exists():
        print("No active configuration registered by UrOwnKeyboard.")
        return
    print(CURRENT_PROFILE.read_text())

def cmd_show_keyd(_args):
    if not CURRENT_PROFILE.exists():
        print("No active configuration registered by UrOwnKeyboard.")
        return
    profile = json.loads(CURRENT_PROFILE.read_text())
    keyd_conf = profile.get("keyd_conf")
    if not keyd_conf:
        print("The active configuration has no associated keyd.conf.")
        return
    path = Path(keyd_conf).expanduser()
    if not path.exists():
        print(f"The active configuration references a missing keyd.conf: {path}")
        return
    print(path.read_text())

def cmd_restore(_args):
    ensure_dirs()
    if not CURRENT_PROFILE.exists():
        result = apply_keyd("")
        if result.returncode == 0:
            print("No active UrOwnKeyboard profile. keyd disabled.")
            return
        raise SystemExit("No active UrOwnKeyboard profile, but keyd could not be disabled.")
    try:
        profile = json.loads(CURRENT_PROFILE.read_text())
    except Exception:
        apply_keyd("")
        raise SystemExit("Invalid current profile file. keyd disabled.")
    profile_type = profile.get("type")
    if profile_type == "imported-profile":
        profile_id = profile.get("id")
        if not profile_id:
            apply_keyd("")
            raise SystemExit("Invalid imported profile. keyd disabled.")

        class Args:
            pass
        args = Args()
        args.profile = profile_id
        return cmd_activate(args)
    result = apply_keyd("")
    if result.returncode == 0:
        print("Regular input source restored. keyd disabled.")
        return
    raise SystemExit("Regular input source restored, but keyd could not be disabled.")

def cmd_editor(_args):
    import os
    import subprocess
    import sys

    candidates = [Path(__file__).resolve().parent / "uok-layout-editor.py",HOME / ".local" / "bin" / "uok-layout-editor.py",
        Path.cwd() / "uok-layout-editor.py"]
    editor = next((path for path in candidates if path.exists()), None)
    if editor is None:
        raise SystemExit("No se encontró uok-layout-editor.py.\n"
            "Ejecuta ./install.sh o abre el editor desde la raíz del repositorio.")
    env = os.environ.copy()
    if not env.get("DISPLAY") and not env.get("WAYLAND_DISPLAY"):
        raise SystemExit("No hay sesión gráfica disponible para abrir el editor.")
    subprocess.Popen([sys.executable, str(editor)],stdin=subprocess.DEVNULL,stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL,env=env,
        start_new_session=True)
    print("Editor visual abierto.")

def run_capture(cmd):
    try:
        return subprocess.run(cmd,text=True,capture_output=True,check=False)
    except FileNotFoundError:
        return None

def _uok_parse_gsettings_sources(value):
    out = []
    for typ, name in re.findall(r"\('([^']+)'\s*,\s*'([^']+)'\)", value or ""):
        if typ == "xkb":
            out.append(name)
        elif typ == "ibus" and name.startswith("xkb:"):
            # xkb:layout:variant:lang
            parts = name.split(":")
            if len(parts) >= 2 and parts[1]:
                layout = parts[1]
                variant = parts[2] if len(parts) >= 3 else ""
                out.append(f"{layout}+{variant}" if variant else layout)
    return out

def _uok_current_layouts_for_doctor():
    layouts = []
    # GNOME / Cinnamon / compatible desktops.
    result = run_capture(["gsettings","get","org.gnome.desktop.input-sources","sources"])
    if result and result.returncode == 0:
        layouts.extend(_uok_parse_gsettings_sources(result.stdout.strip()))
    # X11 / Xwayland fallback.
    result = run_capture(["setxkbmap", "-query"])
    if result and result.stdout:
        m = re.search(r"(?m)^\s*layout:\s*(.+?)\s*$", result.stdout)
        v = re.search(r"(?m)^\s*variant:\s*(.+?)\s*$", result.stdout)
        if m:
            ls = [x.strip() for x in m.group(1).split(",") if x.strip()]
            vs = []
            if v:
                vs = [x.strip() for x in v.group(1).split(",")]
            for i, layout in enumerate(ls):
                variant = vs[i] if i < len(vs) else ""
                layouts.append(f"{layout}+{variant}" if variant else layout)
    # System fallback.
    result = run_capture(["localectl", "status"])
    if result and result.stdout:
        m = re.search(r"(?m)^\s*X11 Layout:\s*(.+?)\s*$", result.stdout)
        v = re.search(r"(?m)^\s*X11 Variant:\s*(.+?)\s*$", result.stdout)
        if m:
            ls = [x.strip() for x in m.group(1).split(",") if x.strip()]
            vs = []
            if v:
                vs = [x.strip() for x in v.group(1).split(",")]
            for i, layout in enumerate(ls):
                variant = vs[i] if i < len(vs) else ""
                layouts.append(f"{layout}+{variant}" if variant else layout)
    # Deduplicate preserving order.
    clean = []
    for item in layouts:
        item = item.strip()
        if item and item not in clean:
            clean.append(item)
    return clean

def _uok_compile_layout(layout):
    if "+" in layout:
        base, variant = layout.split("+", 1)
        if variant:
            return ["xkbcli", "compile-keymap", "--layout", base, "--variant", variant]
        return ["xkbcli", "compile-keymap", "--layout", base]
    return ["xkbcli", "compile-keymap", "--layout", layout]

def _uok_repair_command_for_xkb_registry():
    sudo = [] if os.geteuid() == 0 else ["sudo"]
    if shutil.which("apt"):
        return sudo + ["apt", "install", "--reinstall", "-y", "xkb-data"]
    if shutil.which("dnf"):
        return sudo + ["dnf", "reinstall", "-y", "xkeyboard-config"]
    if shutil.which("pacman"):
        return sudo + ["pacman", "-S", "--noconfirm", "xkeyboard-config"]
    if shutil.which("zypper"):
        return sudo + ["zypper", "install", "-f", "-y", "xkeyboard-config"]
    return None

def _uok_repair_xkb_registry(yes=False):
    cmd = _uok_repair_command_for_xkb_registry()
    if not cmd:
        print("Automatic repair is not available for this distribution.")
        print("Please reinstall the package that provides XKB data/rules.")
        print()
        print("Known examples:")
        print("  Debian / Ubuntu: sudo apt install --reinstall -y xkb-data")
        print("  Fedora:          sudo dnf reinstall -y xkeyboard-config")
        print("  Arch:            sudo pacman -S xkeyboard-config")
        print("  openSUSE:        sudo zypper install -f -y xkeyboard-config")
        return False
    print("Repair command:")
    print("  " + " ".join(cmd))
    print()
    if not yes:
        answer = input("Apply this repair now? [y/N] ").strip().lower()
        if answer not in {"y", "yes", "s", "si", "sí"}:
            print("Repair cancelled.")
            return False
    result = subprocess.run(cmd, check=False)
    return result.returncode == 0

def cmd_doctor(args):
    problems = []
    rules = Path("/usr/share/X11/xkb/rules/evdev.xml")
    dtd = Path("/usr/share/X11/xkb/rules/xkb.dtd")
    print("UrOwnKeyboard doctor")
    print("====================")
    print()
    print("== XKB registry ==")
    if not rules.exists():
        problems.append(f"Missing {rules}")
        print(f"ERROR: missing {rules}")
    else:
        print(f"Found: {rules}")
    if rules.exists() and dtd.exists() and shutil.which("xmllint"):
        result = run_capture(["xmllint","--noout","--dtdvalid",str(dtd),str(rules)])
        if result and result.returncode == 0:
            print("evdev.xml: OK")
        else:
            problems.append("Invalid XKB registry XML: evdev.xml")
            print("ERROR: evdev.xml is invalid")
            if result:
                msg = (result.stderr or result.stdout or "").strip()
                if msg:
                    print(msg[:4000])
    elif rules.exists() and shutil.which("xkbcli"):
        result = run_capture(["xkbcli", "list"])
        output = ""
        if result:
            output = ((result.stdout or "") + "\n" + (result.stderr or "")).strip()
        bad_words = ["xkbregistry: ERROR","XML error","failed to validate","Failed to load"]
        if result is None:
            print("WARNING: could not run xkbcli")
        elif result.returncode != 0 or any(w in output for w in bad_words):
            problems.append("Invalid XKB registry XML: evdev.xml")
            print("ERROR: XKB registry check failed")
            if output:
                print(output[:4000])
        else:
            print("xkbcli registry check: OK")
    else:
        print("WARNING: cannot fully validate evdev.xml.")
        print("Install one of these for stronger checks:")
        print("  sudo apt install -y libxml2-utils libxkbcommon-tools")
    print()
    print("== XKB layout compile ==")
    layouts = _uok_current_layouts_for_doctor()
    if not layouts:
        layouts = ["us"]
        print("Could not detect current layouts; using fallback layout: us")
    else:
        print("Detected layouts:", ", ".join(layouts))
    if shutil.which("xkbcli"):
        for layout in layouts:
            result = run_capture(_uok_compile_layout(layout))
            if result and result.returncode == 0:
                print(f"layout {layout}: OK")
            else:
                problems.append(f"Could not compile XKB layout: {layout}")
                print(f"ERROR: could not compile layout {layout}")
                if result:
                    msg = (result.stderr or result.stdout or "").strip()
                    if msg:
                        print(msg[:4000])
    else:
        print("WARNING: xkbcli not installed; skipping compile check.")
    if not args.system_only:
        print()
        print("== Current session ==")
        checks = [("XDG_CURRENT_DESKTOP", ["bash", "-lc", "printf '%s' \"$XDG_CURRENT_DESKTOP\""]),
            ("DESKTOP_SESSION", ["bash", "-lc", "printf '%s' \"$DESKTOP_SESSION\""]),("XDG_SESSION_TYPE", ["bash", "-lc", "printf '%s' \"$XDG_SESSION_TYPE\""]),
            ("GNOME sources", ["gsettings", "get", "org.gnome.desktop.input-sources", "sources"]),
            ("GNOME current", ["gsettings", "get", "org.gnome.desktop.input-sources", "current"]),("IBus engine", ["ibus", "engine"]),
            ("keyd service", ["systemctl", "is-active", "keyd"])]
        for label, cmd in checks:
            result = run_capture(cmd)
            if result is None:
                print(f"{label}: unavailable")
            else:
                value = (result.stdout or result.stderr or "").strip()
                print(f"{label}: {value}")
    print()
    if problems:
        if getattr(args, "repair", False):
            print("Problems found:")
            for problem in problems:
                print(f"  - {problem}")
            print()
            ok = _uok_repair_xkb_registry(yes=getattr(args, "yes", False))
            if not ok:
                print()
                print("Repair did not complete.")
                if not args.no_fail:
                    raise SystemExit(2)
                return
            print()
            print("Repair completed. Rechecking...")
            print()
            args.repair = False
            return cmd_doctor(args)
        print("Problems found:")
        for problem in problems:
            print(f"  - {problem}")
        print()
        print("Recommended repair on Debian/Ubuntu:")
        print("  sudo apt install --reinstall -y xkb-data")
        print()
        print("Recommended repair on Fedora:")
        print("  sudo dnf reinstall xkeyboard-config")
        print()
        print("Recommended repair on Arch:")
        print("  sudo pacman -S xkeyboard-config")
        print()
        print("After repairing, log out and log back in.")
        if not args.no_fail:
            raise SystemExit(2)
    print("No blocking XKB registry problems detected.")

def main():
    parser = argparse.ArgumentParser(
        prog="uok",
        description="UrOwnKeyboard: portable XKB + keyd configuration manager",
        epilog="""Examples:
  uok list
  uok import --name "My keyboard" --xkb ./my_keyboard
  uok import --name "My keyboard" --xkb ./my_keyboard --keyd ./my_keyboard.keyd.conf
  uok activate my_keyboard
  uok activate es
  uok delete my_keyboard
  uok cleanup-wayland
  uok current
  uok show-keyd
  uok restore
Command-specific help:
  uok import -h
  uok activate -h
  uok delete -h
""",formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = parser.add_subparsers(dest="command", required=True)
    p = sub.add_parser("list", help="List imported configurations")
    p.set_defaults(func=cmd_list)
    p = sub.add_parser("import", help="Import a configuration")
    p.add_argument("--name", required=True, help="Visible configuration name")
    p.add_argument("--xkb", required=True, help="XKB file / symbols")
    p.add_argument("--keyd", help="keyd file.conf opcional")
    p.set_defaults(func=cmd_import)
    p = sub.add_parser("activate", help="Activate a UOK configuration or a detected system source")
    p.add_argument("profile", help="UOK configuration ID/name, system source id, label or index")
    p.set_defaults(func=cmd_activate)
    p = sub.add_parser("delete", help="Delete a configuration")
    p.add_argument("profile", help="Configuration ID or name")
    p.set_defaults(func=cmd_delete)
    p = sub.add_parser("cleanup-wayland", aliases=["cleanup-orphans"], help="Remove orphan/stale UOK GNOME Wayland system layouts")
    p.add_argument("--dry-run", action="store_true", help="Show what would be removed without changing anything")
    p.add_argument("-y", "--yes", action="store_true", help="Do not ask for confirmation")
    p.set_defaults(func=cmd_cleanup_wayland)
    p = sub.add_parser("current", help="Show the registered active configuration")
    p.set_defaults(func=cmd_current)
    p = sub.add_parser("show-keyd", help="Show the keyd.conf associated with the active configuration")
    p.set_defaults(func=cmd_show_keyd)
    p = sub.add_parser("restore", help="Restore the last active UrOwnKeyboard configuration")
    p.set_defaults(func=cmd_restore)
    p = sub.add_parser("editor",aliases=["open-editor","visual-editor","layout-editor"],help="Open the visual keyboard layout editor")
    p.set_defaults(func=cmd_editor)
    p = sub.add_parser("doctor", help="Diagnose XKB, GNOME, IBus and keyd state")
    p.add_argument("--system-only",action="store_true",help="Only check global XKB registry/keymap health")
    p.add_argument("--no-fail",action="store_true",help="Print problems but return success")
    p.add_argument("--repair",action="store_true",help="Try to repair global XKB registry problems by reinstalling the system XKB data package")
    p.add_argument("-y","--yes",action="store_true",help="Do not ask for confirmation when used with --repair")
    p.set_defaults(func=cmd_doctor)
    args = parser.parse_args()
    args.func(args)

if __name__ == "__main__":
    main()