#!/usr/bin/env python3
import argparse
import hashlib
import json
import os
import re
import shlex
import shutil
import subprocess
import sys
from pathlib import Path

HOME = Path.home()
CONFIG_DIR = HOME / ".config" / "teclado-indicador"
PROFILES_DIR = CONFIG_DIR / "profiles"
KEYD_DIR = CONFIG_DIR / "keyd"
CURRENT_FILE = CONFIG_DIR / "current-profile.json"
XKB_SYMBOLS_DIR = HOME / ".xkb" / "symbols"

HELP_TEXT = """Examples:
  uok list
  uok import --name "My keyboard" --xkb ./my_keyboard
  uok import --name "My keyboard" --xkb ./my_keyboard --keyd ./my_keyboard.keyd.conf
  uok activate my_keyboard
  uok delete my_keyboard
  uok current
  uok show-keyd

Command-specific help:
  uok import -h
  uok activate -h
  uok delete -h
"""

def ensure_dirs():
    PROFILES_DIR.mkdir(parents=True, exist_ok=True)
    KEYD_DIR.mkdir(parents=True, exist_ok=True)
    XKB_SYMBOLS_DIR.mkdir(parents=True, exist_ok=True)

def safe_id(name):
    s = name.lower()
    s = re.sub(r"[^a-z0-9]+", "_", s)
    s = s.strip("_")
    return s or "keyboard"

def sha256(path):
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()

def profile_path(profile_id):
    return PROFILES_DIR / f"{profile_id}.json"

def load_profile(profile_id):
    path = profile_path(profile_id)
    if not path.exists():
        raise SystemExit(f"Configuration not found: {profile_id}")
    return json.loads(path.read_text())

def list_profiles():
    ensure_dirs()
    return sorted(PROFILES_DIR.glob("*.json"))

def validate_xkb_layout(layout_id):
    cmd = (
        f'setxkbmap -I"{HOME}/.xkb" -layout {shlex.quote(layout_id)} -print '
        f'| xkbcomp -I"{HOME}/.xkb" -w 10 - /tmp/uok-validate-{shlex.quote(layout_id)}.xkm'
    )
    return subprocess.run(["bash", "-lc", cmd], text=True)

def apply_xkb(layout_id):
    cmd = (
        f'setxkbmap -I"{HOME}/.xkb" -layout {shlex.quote(layout_id)} -print '
        f'| xkbcomp -I"{HOME}/.xkb" -w 0 - "$DISPLAY"'
    )
    return subprocess.run(["bash", "-lc", cmd], text=True)

def apply_keyd(conf_path):
    if not conf_path:
        return True

    conf = Path(conf_path)
    if not conf.exists():
        print(f"WARNING: keyd configuration not found: {conf}", file=sys.stderr)
        return False

    subprocess.run(
        ["sudo", "systemctl", "enable", "--now", "keyd"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        text=True,
    )

    result = subprocess.run(
        ["sudo", "/usr/local/sbin/keyd-aplicar-conf", str(conf)],
        text=True,
    )

    return result.returncode == 0

def restart_indicator_if_running():
    subprocess.run(["pkill", "-f", "teclado-indicador.py"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.run(["bash", "-lc", 'rm -rf "/tmp/uok-indicator-$USER.lock"'], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    launcher = HOME / ".local" / "bin" / "uok-indicator-start"
    if launcher.exists():
        subprocess.Popen([str(launcher)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def cmd_list(_args):
    profiles = list_profiles()
    if not profiles:
        print("No imported configurations.")
        return 0

    for path in profiles:
        try:
            p = json.loads(path.read_text())
            print(f"{p.get('id')} — {p.get('name')}")
        except Exception:
            print(path.stem)
    return 0

def cmd_import(args):
    ensure_dirs()

    src_xkb = Path(args.xkb).expanduser().resolve()
    if not src_xkb.exists():
        print(f"XKB file not found: {src_xkb}", file=sys.stderr)
        return 1

    profile_id = safe_id(args.id or args.name)

    # Avoid exact duplicate XKB imports.
    new_hash = sha256(src_xkb)
    for existing_profile in list_profiles():
        try:
            p = json.loads(existing_profile.read_text())
            old_xkb = Path(p.get("xkb_file", ""))
            if old_xkb.exists() and sha256(old_xkb) == new_hash:
                print(f"Configuration already imported: {p.get('id')} — {p.get('name')}")
                return 0
        except Exception:
            pass

    base_id = profile_id
    n = 2
    while profile_path(profile_id).exists() or (XKB_SYMBOLS_DIR / profile_id).exists():
        profile_id = f"{base_id}_{n}"
        n += 1

    dst_xkb = XKB_SYMBOLS_DIR / profile_id
    shutil.copy2(src_xkb, dst_xkb)

    keyd_conf = ""
    if args.keyd:
        src_keyd = Path(args.keyd).expanduser().resolve()
        if not src_keyd.exists():
            print(f"keyd configuration not found: {src_keyd}", file=sys.stderr)
            return 1
        dst_keyd = KEYD_DIR / f"{profile_id}.conf"
        shutil.copy2(src_keyd, dst_keyd)
        keyd_conf = str(dst_keyd)

    validation = validate_xkb_layout(profile_id)
    if validation.returncode != 0:
        try:
            dst_xkb.unlink()
        except Exception:
            pass
        if keyd_conf:
            try:
                Path(keyd_conf).unlink()
            except Exception:
                pass
        print("Invalid XKB layout. Import cancelled.", file=sys.stderr)
        return 1

    profile = {
        "id": profile_id,
        "name": args.name,
        "xkb_file": str(dst_xkb),
        "keyd_conf": keyd_conf,
    }

    profile_path(profile_id).write_text(json.dumps(profile, indent=2, ensure_ascii=False))
    print(f"Imported: {profile_id} — {args.name}")
    restart_indicator_if_running()
    return 0

def cmd_activate(args):
    ensure_dirs()
    profile = load_profile(args.id)
    profile_id = profile["id"]

    # Apply keyd first. Reloading keyd can make GNOME/X11 restore the keyboard map.
    keyd_ok = apply_keyd(profile.get("keyd_conf", ""))

    # After keyd reloads, apply the XKB layout last.
    subprocess.run(["sleep", "0.7"])

    xkb_result = apply_xkb(profile_id)
    if xkb_result.returncode != 0:
        print("Could not apply the XKB layout.", file=sys.stderr)
        return 1

    CURRENT_FILE.write_text(json.dumps(profile, indent=2, ensure_ascii=False))

    if keyd_ok:
        print(f"Activated: {profile_id} — {profile.get('name')}")
        return 0

    print("The layout was applied, but keyd could not be applied.", file=sys.stderr)
    return 2

